            <rect width="200" height="130" fill="#041208"/>
            <g fill="#1f7a3d" font-size="6" font-family="monospace">
              <text x="10" y="18">@SCREEN  D=A  @addr  M=D</text>
              <text x="10" y="32" fill="#2fa45a">(LOOP)  @KBD  D=M  @WHITE</text>
              <text x="10" y="46">D;JEQ  @BLACK  0;JMP</text>
              <text x="10" y="60" fill="#2fa45a">(BLACK) @color  M=-1</text>
              <text x="10" y="74">@DRAW  0;JMP  (WHITE)</text>
              <text x="10" y="88" fill="#2fa45a">@color  M=0  @DRAW</text>
              <text x="10" y="102">0;JMP  (DRAW)  @color  D=M</text>
              <text x="10" y="116" fill="#2fa45a">@addr  A=M  M=D  @addr</text>
            </g>
          </svg>
        </div>
        <div class="project__body">
