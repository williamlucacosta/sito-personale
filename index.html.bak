<!DOCTYPE html>
<html lang="it">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Luca Costa — Full-Stack Web Developer</title>
<meta name="description" content="Luca Costa — Full-Stack Web Developer e Computer Engineer. Creo esperienze digitali complete, dal design al codice.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Archivo:wdth,wght@62..125,500..900&family=JetBrains+Mono:ital,wght@0,300..800;1,400&display=swap" rel="stylesheet">
<link rel="stylesheet" href="css/style.css">
</head>
<body>

<!-- ====== SFONDO SPAZIALE ====== -->
<div class="space" aria-hidden="true">
  <canvas id="aurora"></canvas>
  <div class="nebula"></div>
  <canvas id="stars"></canvas>
  <div class="vignette"></div>
  <div class="grain"></div>
</div>

<div class="progress-bar" aria-hidden="true"><span id="progressFill"></span></div>

<!-- ====== NAV ====== -->
<header class="nav-wrap">
  <nav class="nav glass">
    <a class="nav__logo" href="#home">Luca Costa</a>
    <ul class="nav__links">
      <li><a href="#about">About</a></li>
      <li><a href="#skills">Skills</a></li>
      <li><a href="#progetti">Progetti</a></li>
      <li><a href="#esperienza">Esperienza</a></li>
      <li><a href="#contatti">Contatti</a></li>
    </ul>
    <a class="btn btn--ghost btn--pill" href="#contatti">Contattami
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 2 11 13M22 2l-7 20-4-9-9-4 20-7z"/></svg>
    </a>
    <button class="nav__burger" aria-label="Menu"><span></span><span></span></button>
  </nav>
</header>

<main>
<!-- ====== HERO ====== -->
<section class="hero" id="home">
  <div class="hero__blob" data-mouse="28">
    <div class="hero__blob-glow"></div>
    <div class="hero__blob-core" data-depth="-0.18">
      <img src="assets/blob.png" alt="" class="hero__blob-img">
      <div class="hero__blob-sheen">
        <i class="sheen sheen--sweep"></i>
        <i class="sheen sheen--drift"></i>
        <i class="sheen sheen--iris"></i>
      </div>
    </div>
    <div class="hero__ring"></div>
    <div class="hero__ring hero__ring--2"></div>
    <span class="orb-dot" style="--x:16%;--y:70%;--s:7px;--d:0s"></span>
    <span class="orb-dot" style="--x:84%;--y:38%;--s:5px;--d:1.4s"></span>
    <span class="orb-dot" style="--x:64%;--y:88%;--s:6px;--d:2.6s"></span>
    <span class="orb-dot" style="--x:38%;--y:18%;--s:4px;--d:3.5s"></span>
  </div>

  <div class="container hero__content">
    <p class="kicker reveal"><span class="kicker__num">[ 01 ]</span> FULL-STACK WEB DEVELOPER <span class="kicker__dot">·</span> COMPUTER ENGINEER<span class="caret"></span></p>
    <h1 class="hero__title" data-mouse="-10">
      <span class="hero__line"><span>Luca</span></span>
      <span class="hero__line"><span>Costa</span></span>
    </h1>
    <p class="hero__sub reveal" style="--d:.55s">Creo esperienze digitali complete, dal design al codice.<br>Performance, eleganza e logica al servizio delle idee.</p>
    <div class="hero__cta reveal" style="--d:.7s">
      <a href="#progetti" class="btn btn--primary magnetic">Vedi i progetti
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14m-6-6 6 6-6 6"/></svg>
      </a>
      <a href="#contatti" class="btn btn--ghost magnetic">Contattami
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="2" y="4" width="20" height="16" rx="3"/><path d="m2 7 10 7L22 7"/></svg>
      </a>
    </div>
    <div class="hero__scroll reveal" style="--d:.9s">
      <svg width="12" height="26" viewBox="0 0 12 26" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M6 1v20m0 0-4-4m4 4 4-4" class="scroll-arrow"/></svg>
      <span>SCROLL<br>PER SCOPRIRE</span>
    </div>
  </div>
</section>

<!-- ====== ABOUT ====== -->
<section class="section" id="about">
  <div class="container">
    <h2 class="section__label reveal"><span>[ 02 ]</span> ABOUT</h2>
    <div class="about-grid">
      <article class="card glass reveal tilt">
        <div class="card__icon pulse-ring">
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><circle cx="12" cy="8" r="4"/><path d="M4 21c0-4 3.6-6.5 8-6.5s8 2.5 8 6.5"/></svg>
        </div>
        <p>Sono Luca Costa, sviluppatore full-stack e ingegnere informatico. Mi occupo di progettare e realizzare applicazioni web performanti, sistemi backend robusti e interfacce moderne.</p>
        <p>Amo trasformare problemi complessi in soluzioni eleganti e scalabili.</p>
      </article>
      <div class="about-langs">
        <article class="card card--row glass reveal tilt" style="--d:.12s">
          <div class="card__icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2c2.7 2.7 4 6.2 4 10s-1.3 7.3-4 10c-2.7-2.7-4-6.2-4-10s1.3-7.3 4-10z"/></svg>
          </div>
          <div>
            <h3 class="card__eyebrow">LINGUA MADRE</h3>
            <p class="card__value"><span class="tag-mini">IT</span> Italiano</p>
          </div>
        </article>
        <article class="card card--row glass reveal tilt" style="--d:.24s">
          <div class="card__icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M21 12c0 4-4 7-9 7-1.2 0-2.4-.2-3.4-.5L3 20l1.7-3.4C3.6 15.3 3 13.7 3 12c0-4 4-7 9-7s9 3 9 7z"/></svg>
          </div>
          <div>
            <h3 class="card__eyebrow">LINGUA STRANIERA</h3>
            <p class="card__value"><span class="tag-mini">EN</span> Inglese B2</p>
          </div>
        </article>
      </div>
    </div>
  </div>
</section>

<!-- ====== SKILLS ====== -->
<section class="section" id="skills">
  <div class="container">
    <h2 class="section__label reveal"><span>[ 03 ]</span> SKILLS</h2>
    <div class="skills-grid">
      <article class="card glass skills-key reveal tilt">
        <div class="card__icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="m12 2 2.9 6.3 6.9.8-5.1 4.7 1.4 6.8L12 17.2l-6.1 3.4 1.4-6.8L2.2 9.1l6.9-.8L12 2z"/></svg>
        </div>
        <h3 class="card__title">Key Competencies</h3>
        <ul class="key-list">
          <li>Problem Solving</li>
          <li>Clean Code</li>
          <li>Performance</li>
          <li>User Experience</li>
          <li>Teamwork</li>
          <li>Continuous Learning</li>
        </ul>
      </article>

      <article class="card glass skill reveal tilt" style="--d:.08s">
        <div class="card__icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="m8 7-5 5 5 5m8-10 5 5-5 5m-3-12-2 14"/></svg></div>
        <div><h3 class="card__title">Front-End</h3>
        <p class="skill__tags">React&nbsp;&nbsp;Next.js&nbsp;&nbsp;TypeScript<br>HTML&nbsp;&nbsp;CSS&nbsp;&nbsp;Tailwind</p></div>
      </article>

      <article class="card glass skill reveal tilt" style="--d:.16s">
        <div class="card__icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="3" y="4" width="18" height="7" rx="2"/><rect x="3" y="13" width="18" height="7" rx="2"/><path d="M7 7.5h.01M7 16.5h.01"/></svg></div>
        <div><h3 class="card__title">Back-End</h3>
        <p class="skill__tags">Node.js&nbsp;&nbsp;Express&nbsp;&nbsp;PHP<br>MySQL&nbsp;&nbsp;REST&nbsp;API</p></div>
      </article>

      <article class="card glass skill reveal tilt" style="--d:.24s">
        <div class="card__icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="3" y="3" width="18" height="14" rx="3"/><circle cx="8.5" cy="10" r="1.5"/><circle cx="15.5" cy="10" r="1.5"/><path d="M8 21h8"/></svg></div>
        <div><h3 class="card__title">Software Dev</h3>
        <p class="skill__tags">C++&nbsp;&nbsp;Python&nbsp;&nbsp;Java<br>OOP&nbsp;&nbsp;DSA&nbsp;&nbsp;Git</p></div>
      </article>

      <article class="card glass skill reveal tilt" style="--d:.12s">
        <div class="card__icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="2" y="7" width="20" height="11" rx="4"/><path d="M7 11v3m-1.5-1.5h3M15.5 11h.01M18 13.5h.01"/></svg></div>
        <div><h3 class="card__title">Game Dev</h3>
        <p class="skill__tags">Unity&nbsp;&nbsp;C#&nbsp;&nbsp;2D<br>Gameplay,&nbsp;Systems</p></div>
      </article>

      <article class="card glass skill reveal tilt" style="--d:.2s">
        <div class="card__icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="m12 2 8 4.5v9L12 20l-8-4.5v-9L12 2z"/><path d="M12 11 4 6.5M12 11l8-4.5M12 11v9"/></svg></div>
        <div><h3 class="card__title">Grafica 3D</h3>
        <p class="skill__tags">Blender&nbsp;&nbsp;Modeling&nbsp;&nbsp;Texturing<br>Lighting,&nbsp;Rendering</p></div>
      </article>

      <article class="card glass skill reveal tilt" style="--d:.28s">
        <div class="card__icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M14.5 4.5 19 9 7.5 20.5 3 21l.5-4.5L14.5 4.5zM12 7l4.5 4.5"/></svg></div>
        <div><h3 class="card__title">Tools &amp; Design</h3>
        <p class="skill__tags">Git&nbsp;&nbsp;Docker&nbsp;&nbsp;Figma<br>VS&nbsp;Code,&nbsp;Postman</p></div>
      </article>
    </div>

    <div class="ticker glass reveal" aria-hidden="true">
      <div class="ticker__track">
        <span>REACT</span><i>·</i><span>NEXT.JS</span><i>·</i><span>TYPESCRIPT</span><i>·</i><span>NODE.JS</span><i>·</i><span>MYSQL</span><i>·</i><span>TAILWIND</span><i>·</i><span>PHP</span><i>·</i><span>UNITY</span><i>·</i><span>BLENDER</span><i>·</i><span>FIGMA</span><i>·</i><span>DOCKER</span><i>·</i>
        <span>REACT</span><i>·</i><span>NEXT.JS</span><i>·</i><span>TYPESCRIPT</span><i>·</i><span>NODE.JS</span><i>·</i><span>MYSQL</span><i>·</i><span>TAILWIND</span><i>·</i><span>PHP</span><i>·</i><span>UNITY</span><i>·</i><span>BLENDER</span><i>·</i><span>FIGMA</span><i>·</i><span>DOCKER</span><i>·</i>
      </div>
    </div>
  </div>
</section>

