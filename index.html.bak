</section>

<!-- ====== ESPERIENZA ====== -->
<section class="section" id="esperienza">
  <div class="container">
    <h2 class="section__label reveal"><span>[ 05 ]</span> ESPERIENZA</h2>
    <div class="timeline">
      <article class="timeline__item reveal">
        <div class="timeline__dot"></div>
        <div class="card glass tilt">
          <span class="card__eyebrow">2024 — OGGI</span>
          <h3 class="card__title">Full-Stack Developer · Freelance</h3>
          <p>Progettazione e sviluppo di applicazioni web complete per clienti e progetti personali: front-end moderni, API REST, database e deploy.</p>
        </div>
      </article>
      <article class="timeline__item reveal" style="--d:.15s">
        <div class="timeline__dot"></div>
        <div class="card glass tilt">
          <span class="card__eyebrow">2023 — 2024</span>
          <h3 class="card__title">Game Developer · Progetti Unity</h3>
          <p>Sviluppo di giochi 2D in Unity: gameplay systems, level design, fisica e ottimizzazione delle performance.</p>
        </div>
      </article>
      <article class="timeline__item reveal" style="--d:.3s">
        <div class="timeline__dot"></div>
        <div class="card glass tilt">
          <span class="card__eyebrow">2021 — IN CORSO</span>
          <h3 class="card__title">Ingegneria Informatica</h3>
          <p>Percorso di studi in computer engineering: architettura dei calcolatori, algoritmi e strutture dati, sistemi operativi, reti.</p>
        </div>
      </article>
    </div>
  </div>
</section>

