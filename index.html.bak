      <span>Designed &amp; built in the void <span class="footer__dot">✦</span></span>
    </footer>
  </div>
</section>
</main>

<!-- toast -->
<div class="toast glass" id="toast" role="status" aria-live="polite">
  <div class="toast__icon">✦</div>
  <div><strong id="toastTitle">Layout in preparazione</strong><span id="toastSub">Sto preparando il sito</span></div>
</div>

<script src="js/main.js"></script>
</body>
</html>
